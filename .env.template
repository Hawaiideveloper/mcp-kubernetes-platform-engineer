# Environment Configuration Template
# Copy this file to .env and customize for your environment

# ===== Kubernetes Configuration =====
KUBECONFIG=/root/.kube/config
K8S_NAMESPACE=default
K8S_CONTEXT=
K8S_CLUSTER_NAME=
K8S_TIMEOUT=30

# ===== MCP Server Configuration =====
MCP_HOST=0.0.0.0
MCP_PORT=3000
DEBUG=false

# ===== Monitoring Configuration =====
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
ALERTMANAGER_URL=http://alertmanager:9093
ENABLE_METRICS=true
METRICS_PORT=8080

# ===== Logging Configuration =====
LOG_LEVEL=INFO
LOG_FILE=/app/logs/k8s-platform-engineer.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# ===== Security Configuration =====
RBAC_ENABLED=true
POD_SECURITY_STANDARDS=true
NETWORK_POLICIES=true

# ===== Diagnostics Configuration =====
ENABLE_PERF_MONITORING=true
ENABLE_NET_DIAGNOSTICS=true
ENABLE_STORAGE_DIAGNOSTICS=true
ENABLE_RUNTIME_DIAGNOSTICS=true
DIAGNOSTIC_TIMEOUT=60
MAX_CONCURRENT_DIAGNOSTICS=5
